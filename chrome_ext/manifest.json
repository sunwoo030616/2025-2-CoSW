{
  "manifest_version": 3,
  "name": "Lost112 Chatbot",
  "version": "1.0.0",
  "description": "경찰청 유실물 챗봇 - 분실물을 쉽고 빠르게 찾아보세요",
  
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  
  "permissions": [
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1:8000/*",
    "https://*.herokuapp.com/*",
    "https://*.vercel.app/*",
    "https://*.netlify.app/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://www.lost112.go.kr/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "chat_window.html",
        "chat_window.css",
        "chat_window.js",
        "icon.png"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}
