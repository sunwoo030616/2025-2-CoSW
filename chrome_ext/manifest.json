{
    "manifest_version": 3,
    "name": "Django Extension",
    "version": "0.1.0",
    "description": "장고 API와 통신하는 확장 프로그램",
    "action": {
        "default_popup": "popup.html",
        "default_title": "Django Extension"
    },
    "permissions": ["storage"],
    "host_permissions": ["http://127.0.0.1:8000/*", "http://localhost:8000/*"],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ]
}
